<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="practicasprofesionales.controlador.ControladorGUIInicioSesion">
    <center>
        <StackPane prefHeight="600.0" prefWidth="930.0" style="-fx-background-color: #f8fafc;">
           <children>
   
               <VBox alignment="CENTER" maxWidth="380" spacing="0">
      <children>
                  <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="SPP UV" />
      
                      <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Iniciar Sesión">
                          <VBox.margin>
                        <Insets bottom="6" />
                     </VBox.margin>
                      </Label>
      
                      <Label style="-fx-font-size: 13px; -fx-text-fill: #64748b;" text="Ingresa tus credenciales para acceder al sistema">
                          <VBox.margin>
                        <Insets bottom="40" />
                     </VBox.margin>
                      </Label>
      
                      <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;" text="Correo electrónico">
                          <VBox.margin>
                        <Insets bottom="6" />
                     </VBox.margin>
                      </Label>
                      <TextField fx:id="txt_correo" prefHeight="44" prefWidth="360" promptText="usuario@ejemplo.com" style="-fx-background-color: white;                                   -fx-border-color: #d1d5db;                                   -fx-border-radius: 8;                                   -fx-background-radius: 8;                                   -fx-padding: 10 14;                                   -fx-font-size: 14px;">
                          <VBox.margin>
                        <Insets bottom="18" />
                     </VBox.margin>
                      </TextField>
      
                      <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;" text="Contraseña">
                          <VBox.margin>
                        <Insets bottom="6" />
                     </VBox.margin>
                      </Label>
                      <PasswordField fx:id="txt_contrasena" prefHeight="44" prefWidth="360" promptText="••••••••" style="-fx-background-color: white;                                       -fx-border-color: #d1d5db;                                       -fx-border-radius: 8;                                       -fx-background-radius: 8;                                       -fx-padding: 10 14;                                       -fx-font-size: 14px;">
                          <VBox.margin>
                        <Insets bottom="8" />
                     </VBox.margin>
                      </PasswordField>
      
                      <Label fx:id="lbl_error" maxWidth="360" style="-fx-text-fill: #ef4444; -fx-font-size: 12px;" text="" wrapText="true">
                          <VBox.margin>
                        <Insets bottom="18" />
                     </VBox.margin>
                      </Label>
      
                      <Button fx:id="btn_ingresar" defaultButton="true" onAction="#manejarInicioSesion" prefHeight="46" prefWidth="360" style="-fx-background-color: #185244; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Iniciar sesión">
                          <VBox.margin>
                        <Insets bottom="24" />
                     </VBox.margin>
                      </Button>
      
                      <Label alignment="CENTER" maxWidth="360" style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;" text="v1.0 · Sistema de Prácticas Profesionales" />
      </children>
   
               </VBox>
           </children>
        </StackPane>
    </center>

</BorderPane>
