<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="practicasprofesionales.controlador.FXMLAgregarFormatoController">
    <children>
      <VBox layoutX="20.0" layoutY="20.0" spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <Label text="Seleccionar Documento" textFill="#185244">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font></Label>
               <Label text="Tipo de Documento:" />
               <ComboBox fx:id="cbxTipoDocumento" prefWidth="560.0" promptText="Seleccione el tipo de formato..." />
            <HBox spacing="10.0">
               <children>
                  <TextField fx:id="txfRutaArchivo" editable="false" HBox.hgrow="ALWAYS" />
                  <Button onAction="#btnSeleccionar" text="Seleccionar..." />
               </children>
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button onAction="#btnCancelar" text="Cancelar" />
                  <Button onAction="#btnGuardar" style="-fx-background-color: #185244; -fx-text-fill: white;" text="Guardar" />
               </children>
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
