                        <Button mnemonicParsing="false" style="-fx-background-color: #185244; -fx-text-fill: white;" text="Eliminar Documento" BorderPane.alignment="CENTER" />
                     </right>
                     <left>
                        <Label text="Seleccione uno de la tabla antes de presionar eliminar:" BorderPane.alignment="CENTER" />
                     </left>
                  </BorderPane>
               </children>
            </AnchorPane>
         </children>
      </VBox>
   </children>
</AnchorPane>
