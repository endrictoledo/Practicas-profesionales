               </children>
            </HBox>
            <TableView fx:id="tbl_Formatos" prefHeight="261.0" prefWidth="623.0" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="tbc_Estado" prefWidth="255.0" text="Tipo de documento" />
                  <TableColumn fx:id="tbc_Nombre" prefWidth="395.0" text="Nombre del  archivo" />
               </columns>
            </TableView>
            <AnchorPane prefHeight="44.0" prefWidth="623.0">
               <children>
                  <BorderPane layoutY="134.0" prefHeight="44.0" prefWidth="737.0">
