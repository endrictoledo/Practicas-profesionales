<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<AnchorPane prefHeight="700.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="practicasprofesionales.controlador.ControladorGUIRegistrarProyecto">
   <children>
      <VBox layoutX="20.0" layoutY="20.0" prefHeight="660.0" prefWidth="560.0" spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <Label text="Registrar Proyecto" textFill="#185244">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>

            <Label text="1. Organización Vinculada">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Label>
            <ComboBox fx:id="cbx_Organizaciones" prefWidth="560.0" promptText="Seleccionar Organización" style="-fx-font-size: 14px;" />

            <Label text="2. Datos del Proyecto">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Label>
            <GridPane hgap="10.0" vgap="10.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="275.0" minWidth="10.0" prefWidth="150.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="410.0" minWidth="10.0" prefWidth="410.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="60.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Label text="Nombre del Proyecto:" />
                  <TextField fx:id="txf_NombreProyecto" GridPane.columnIndex="1" />
                  
                  <Label text="Descripción:" GridPane.rowIndex="1" />
                  <TextArea fx:id="txf_Descripcion" prefHeight="60.0" prefWidth="200.0" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  
                  <Label text="Objetivo:" GridPane.rowIndex="2" />
                  <TextField fx:id="txf_Objetivo" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  
                  <Label text="Cupo:" GridPane.rowIndex="3" />
                  <TextField fx:id="txf_Cupo" GridPane.columnIndex="1" GridPane.rowIndex="3" />
               </children>
            </GridPane>

            <Label text="3. Datos del Encargado">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Label>
            <GridPane hgap="10.0" vgap="10.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" maxWidth="275.0" minWidth="10.0" prefWidth="150.0" />
                  <ColumnConstraints hgrow="SOMETIMES" maxWidth="410.0" minWidth="10.0" prefWidth="410.0" />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
               </rowConstraints>
               <children>
                  <Label text="Nombre:" />
                  <TextField fx:id="txf_NombreEncargado" GridPane.columnIndex="1" />
                  
                  <Label text="Apellido Paterno:" GridPane.rowIndex="1" />
                  <TextField fx:id="txf_ApellidoPaEncargado" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  
                  <Label text="Apellido Materno:" GridPane.rowIndex="2" />
                  <TextField fx:id="txf_ApellidoMaEncargado" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  
                  <Label text="Cargo:" GridPane.rowIndex="3" />
                  <TextField fx:id="txf_Cargo" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  
                  <Label text="Correo Electrónico:" GridPane.rowIndex="4" />
                  <TextField fx:id="txf_CorreoEncargado" GridPane.columnIndex="1" GridPane.rowIndex="4" />
               </children>
            </GridPane>
            
            <HBox alignment="CENTER_RIGHT" prefHeight="50.0" prefWidth="200.0" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#btn_Cancelar" prefHeight="35.0" prefWidth="120.0" style="-fx-cursor: hand;" text="Cancelar" />
                  <Button mnemonicParsing="false" onAction="#btn_Registrar" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #185244; -fx-text-fill: white; -fx-cursor: hand;" text="Registrar" />
               </children>
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
