<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="450.0" prefWidth="550.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="practicasprofesionales.controlador.FXMLAsignarProyectoController">
    <children>
        <VBox layoutX="20.0" layoutY="20.0" prefWidth="510.0" spacing="10.0">
            <Label text="Proyectos solicitados (por prioridad):" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
            
            <TableView fx:id="tblProyectosPrioridad" prefHeight="250.0" prefWidth="510.0">
                <columns>
                    <TableColumn fx:id="colPrioridad" text="Prioridad" prefWidth="80.0" />
                    <TableColumn fx:id="colNombreProyecto" text="Nombre Proyecto" prefWidth="300.0" />
                    <TableColumn fx:id="colCupo" text="Cupo" prefWidth="128.0" />
                </columns>
            </TableView>

            <HBox spacing="20.0" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                <VBox spacing="5.0">
                    <Label text="Fecha de Inicio:" />
                    <DatePicker fx:id="dpFechaInicio" prefWidth="240.0" />
                </VBox>
                <VBox spacing="5.0">
                    <Label text="Fecha de Fin:" />
                    <DatePicker fx:id="dpFechaFin" prefWidth="240.0" />
                </VBox>
            </HBox>

            <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 10 0 0 0;">
                <Button text="Cancelar" onAction="#btnCancelar" prefWidth="100.0" style="-fx-cursor: hand;" />
                <Button text="Asignar Proyecto" onAction="#btnAsignar" prefWidth="150.0" 
                        style="-fx-background-color: #185244; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>